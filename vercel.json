{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://charitha.runasp.net/api/:path*"
    },
    {
      "source": "/dev-api/:path*",
      "destination": "http://janasiri-api.runasp.net/api/:path*"
    },
    {
      "source": "/hubs/:path*",
      "destination": "http://charitha.runasp.net/hubs/:path*"
    },
    {
      "source": "/dev-hubs/:path*",
      "destination": "http://janasiri-api.runasp.net/hubs/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}